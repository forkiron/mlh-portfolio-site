# Template for .deploy.env — copy this to the repo root as `.deploy.env` and fill it in.
#   cp scripts/deploy.example.env .deploy.env
# .deploy.env is gitignored so your secrets never get pushed.

# SSH target for the VPS (user@ip)
VPS_HOST=root@YOUR_DROPLET_IP

# Where the repo lives on the VPS
REMOTE_DIR=~/mlh-portfolio-site

# tmux session name that runs Flask
TMUX_SESSION=portfolio

# Port Flask serves on
APP_PORT=5000

# Optional: your public site URL (printed after deploy). Leave blank to print the IP.
DUCKDNS_URL=

# Optional: SSH/key password. Only used if `sshpass` is installed.
# Preferred instead: add your key to the macOS keychain once (see the skill).
VPS_PASS=
